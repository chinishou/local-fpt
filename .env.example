# ============================================================
#  local-fpt: Local Flow Production Tracking Backend
# ============================================================
# Copy this file to .env and fill in values.
# Secrets are never committed.

# ----- Server -----
FPT_HOST=127.0.0.1
FPT_PORT=8000
FPT_DB_PATH=fpt_local.db
FPT_AUTH_MODE=disabled

# ----- Pagination Defaults -----
FPT_DEFAULT_PAGE_SIZE=100
FPT_MAX_PAGE_SIZE=2000

# ----- Paid SG site for live TDD (from .env — do not commit) -----
SG_URL=https://wei-dev.shotgrid.autodesk.com
SCRIPT_NAME=dev
API_KEY=your-api-key-here
